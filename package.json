{
  "name": "visual-qontract",
  "version": "0.0.0",
  "private": true,
  "dependencies": {
    "@patternfly/react-core": "^6.0.0",
    "apollo-boost": "^0.4.1",
    "chroma-js": "2.1.0",
    "classnames": "^2.2.6",
    "eslint-plugin-import": "^2.16.0",
    "eslint-plugin-patternfly-react": "^0.2.3",
    "graphql": "^14.2.1",
    "lodash.orderby": "^4.6.0",
    "ncp": "^2.0.0",
    "numeral": "^2.0.6",
    "patternfly-react": "2.36.1",
    "prop-types": "^15.7.2",
    "react": "^16.8.6",
    "react-apollo": "^2.5.3",
    "react-dom": "^16.8.6",
    "react-markdown": "^8.0.3",
    "react-router": "^5.0.0",
    "react-router-dom": "^5.0.0",
    "react-scripts": "2.1.8",
    "react-select": "^3.1.0",
    "react-tooltip": "^4.2.21",
    "recompose": "^0.30.0",
    "sass": "^1.32.8",
    "sortabular": "^1.6.0",
    "table-resolver": "^4.1.1"
  },
  "devDependencies": {
    "eslint": "5.12.0",
    "eslint-config-airbnb": "17.1.0",
    "eslint-plugin-jsx-a11y": "6.1.2",
    "eslint-plugin-react": "7.12.4",
    "npm-run-all": "^4.1.3",
    "prettier": "1.18.2",
    "source-map-explorer": "^1.5.0"
  },
  "scripts": {
    "copy-fonts": "ncp node_modules/patternfly/dist/fonts src/fonts",
    "copy-img": "ncp node_modules/patternfly/dist/img src/img",
    "build-css": "sass --style compressed --load-path src --load-path node_modules/patternfly/dist/sass --load-path node_modules/patternfly-react/dist/sass --load-path node_modules/bootstrap-sass/assets/stylesheets --load-path node_modules/font-awesome-sass/assets/stylesheets src/",
    "watch-css": "npm run build-css && sass --watch --style compressed --load-path src --load-path node_modules/patternfly/dist/sass --load-path node_modules/patternfly-react/dist/sass --load-path node_modules/bootstrap-sass/assets/stylesheets --load-path node_modules/font-awesome-sass/assets/stylesheets src/",
    "build-js": "react-scripts --openssl-legacy-provider build",
    "start:dev": "npm-run-all -p watch-css start:local build-fragment",
    "start:local": "react-scripts --openssl-legacy-provider start",
    "build": "npm run copy-fonts && npm run copy-img && npm run build-css && npm run build-js && npm run postbuild",
    "test": "npm run lint && react-scripts --openssl-legacy-provider test --env=jsdom --watchAll=false",
    "eject": "react-scripts --openssl-legacy-provider eject",
    "prettier": "prettier --write --single-quote --trailing-comma=none \"src/**/*.js\"",
    "analyze": "source-map-explorer build/static/js/main.*",
    "lint": "npm run lint:js",
    "lint:js": "npm run build-css && eslint --cache --max-warnings 0 src",
    "preinstall": "node -v; npm -v;",
    "postbuild": "[ \"$BUILD_ENV\" != OCP ] && exit 0; npm install --omit=dev --ignore-scripts --prefer-offline;",
    "build-fragment": "node src/fragmentTypesGenerator.js"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
