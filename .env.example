# GraphQL endpoint configuration
# Default: http://localhost:4000/graphql
REACT_APP_GRAPHQL_ENDPOINT=http://localhost:4000/graphql

# Data directory URL for git repository paths
# Default: https://path/to/data
REACT_APP_DATA_DIR_URL=https://path/to/data

# Documentation directory URL
# Default: https://path/to/docs
REACT_APP_DOCS_DIR_URL=https://path/to/docs

# Schemas directory URL
# Default: https://path/to/schemas
REACT_APP_SCHEMAS_DIR=https://path/to/schemas

# Grafana dashboards URL
# Default: https://path/to/grafana
REACT_APP_GRAFANA_URL=https://path/to/grafana