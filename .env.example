# Visual-Qontract Local Development Environment
# Copy this file to .env for local development: cp .env.example .env

# =============================================================================
# GraphQL API Endpoint
# =============================================================================
# Point to your local qontract-server or a remote instance
REACT_APP_GRAPHQL_ENDPOINT=http://localhost:4000/graphql

# =============================================================================
# External Resource URLs (Optional)
# =============================================================================
# These are used to generate links to external resources
# For local development, you can use placeholder values or point to real instances

# GitLab/GitHub data directory (used for "View in GitLab" links)
REACT_APP_DATA_DIR_URL=https://example.com/data

# Documentation directory (used for "View Docs" links)
REACT_APP_DOCS_DIR_URL=https://example.com/docs

# Schema repository (used for "View Schema" links)
REACT_APP_SCHEMAS_DIR=https://example.com/schemas

# Grafana instance (used for "View Dashboard" links)
REACT_APP_GRAFANA_URL=https://example.com/grafana

# =============================================================================
# Local Development Quick Start
# =============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Start qontract-server locally (see qontract-server docs)
# 3. Run: npm install --legacy-peer-deps
# 4. Run: npm start
# 5. Open: http://localhost:3000
#
# The app will use default placeholder values if .env is not present.
# For production deployments, see APP_INTERFACE_CHANGES.md