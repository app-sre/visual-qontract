# Visual App-Interface Environment Configuration
# Copy this file to .env and customize the values for your environment

# =============================================================================
# DEVELOPMENT ENVIRONMENT VARIABLES
# =============================================================================

# GraphQL API Configuration
REACT_APP_GRAPHQL_ENDPOINT=http://localhost:4000/graphql
AUTHORIZATION=

# External Service URLs
REACT_APP_DATA_DIR_URL=https://data.devshift.net
REACT_APP_DOCS_DIR_URL=https://docs.devshift.net
REACT_APP_SCHEMAS_DIR=https://schemas.devshift.net
REACT_APP_GRAFANA_URL=https://grafana.devshift.net

# Container Configuration (for podman-compose)
HOST_PORT=8080

# =============================================================================
# PRODUCTION DEPLOYMENT NOTES
# =============================================================================
#
# For production deployments on OpenShift/Kubernetes, these environment
# variables should be set through ConfigMaps and Secrets, not .env files.
#
# The container supports runtime environment variable injection, meaning
# the same image can be used across different environments with different
# configurations.
#
# See deployment/openshift/ directory for example manifests.
#
# =============================================================================
# ENVIRONMENT EXAMPLES
# =============================================================================

# Development
# REACT_APP_GRAPHQL_ENDPOINT=http://localhost:4000/graphql
# AUTHORIZATION=Bearer your-dev-token
# REACT_APP_DATA_DIR_URL=https://data.dev.example.com
# REACT_APP_DOCS_DIR_URL=https://docs.dev.example.com
# REACT_APP_SCHEMAS_DIR=https://schemas.dev.example.com
# REACT_APP_GRAFANA_URL=https://grafana.dev.example.com

# Staging
# REACT_APP_GRAPHQL_ENDPOINT=https://app-interface.staging.example.com/graphql
# AUTHORIZATION=Bearer your-staging-token
# REACT_APP_DATA_DIR_URL=https://data.staging.example.com
# REACT_APP_DOCS_DIR_URL=https://docs.staging.example.com
# REACT_APP_SCHEMAS_DIR=https://schemas.staging.example.com
# REACT_APP_GRAFANA_URL=https://grafana.staging.example.com

# Production
# REACT_APP_GRAPHQL_ENDPOINT=https://app-interface.production.example.com/graphql
# AUTHORIZATION=Bearer your-production-token
# REACT_APP_DATA_DIR_URL=https://data.production.example.com
# REACT_APP_DOCS_DIR_URL=https://docs.production.example.com
# REACT_APP_SCHEMAS_DIR=https://schemas.production.example.com
# REACT_APP_GRAFANA_URL=https://grafana.production.example.com
